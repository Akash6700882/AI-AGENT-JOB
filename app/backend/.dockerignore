# Python
__pycache__/
__pychache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
.pytest_cache/

# Virtual environments (never bake a local venv into the image — the
# Dockerfile builds its own inside the container)
venv/
.venv/
env/

# Local data / secrets — these must come from the environment or a mounted
# volume at runtime, never baked into the image
.env
.env.*
!.env.example
data/
temp_uploads/
*.db
applications.json

# Editor / OS
.vscode/
.idea/
.DS_Store
tempCodeRunnerFile.py

# Tests (not needed in the runtime image; add a separate CI step if you
# want tests to run as part of the build pipeline instead)
tests/

# VCS
.git/
.gitignore

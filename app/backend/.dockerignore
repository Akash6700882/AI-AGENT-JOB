# The backend lives in a subfolder of this same directory but is a
# completely separate build context (see backend/Dockerfile) — excluding
# it here keeps the frontend build context small and avoids ever copying
# Python source, venvs, or backend secrets into the frontend image.
backend/

node_modules/
dist/
.vite/

# Local env files — VITE_API_URL etc. come from docker-compose build args,
# not a baked-in .env inside the image
.env
.env.*
!.env.example

# Editor / OS
.vscode/
.idea/
.DS_Store

# VCS
.git/
.gitignore

# Misc project files not needed for the build
*.md
job-agent/
AI-Job-Agent1/
venv/